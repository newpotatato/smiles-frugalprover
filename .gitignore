# Python
__pycache__/
*.pyc
*.pyo

# DocuMentor parse caches -- regenerable from the source PDFs/MD via the
# documentor skill, not worth versioning (images + JSON graphs, several MB)
.documentor/
**/.documentor/

# Local Claude Code config/memory -- not part of the shared team repo
.claude/

# OS/editor junk
.DS_Store
Thumbs.db
.vscode/

# Superseded by this repo (was a manual zip snapshot before git existed here)
FrugalProver_TeamPackage.zip
_package_staging/

# Pipeline artifacts. Every one of these is regenerable from a config
# (`frugalprover run-all --config ...`), and the hidden states in particular
# are large: pooled vectors at all ~29 layers for a few hundred problems run
# to tens of MB, and the raw JSON equivalent blew past GitHub's 100MB limit.
# Shared out-of-band (Drive) rather than committed.
data/*/
!data/.gitkeep

# Run outputs. The oracle (.joblib), metrics.json and plots are small, but
# they're derived artifacts -- results are reported in slides/ and docs/, and
# a run is reproduced from its config.yaml rather than pulled from git.
results/*/
!results/.gitkeep

# Editable-install / build metadata
src/*.egg-info/
*.egg-info/
build/

# LaTeX build output for the slide deck (regenerable from frugalprover.tex).
slides/out/
